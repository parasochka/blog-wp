{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"customDuotone": false,
			"palette": [
				{ "slug": "base", "color": "#ffffff", "name": "Base / Background" },
				{ "slug": "surface", "color": "#f5f5f7", "name": "Surface" },
				{ "slug": "surface-strong", "color": "#eeeef2", "name": "Surface Strong" },
				{ "slug": "contrast", "color": "#111114", "name": "Contrast / Text" },
				{ "slug": "muted", "color": "#6b6b76", "name": "Muted Text" },
				{ "slug": "border", "color": "#e5e5ea", "name": "Border" },
				{ "slug": "primary", "color": "#4f46e5", "name": "Primary / Accent" },
				{ "slug": "primary-hover", "color": "#4338ca", "name": "Primary Hover" },
				{ "slug": "secondary", "color": "#0ea5e9", "name": "Secondary" },
				{ "slug": "accent", "color": "#f59e0b", "name": "Accent" }
			],
			"gradients": [
				{
					"slug": "brand",
					"gradient": "linear-gradient(135deg, #4f46e5 0%, #0ea5e9 100%)",
					"name": "Brand"
				},
				{
					"slug": "subtle",
					"gradient": "linear-gradient(180deg, #f5f5f7 0%, #ffffff 100%)",
					"name": "Subtle"
				}
			]
		},
		"typography": {
			"fluid": true,
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"slug": "sans",
					"name": "Sans",
					"fontFamily": "\"Inter\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif"
				},
				{
					"slug": "serif",
					"name": "Serif",
					"fontFamily": "\"Newsreader\", Georgia, \"Times New Roman\", serif"
				},
				{
					"slug": "mono",
					"name": "Mono",
					"fontFamily": "\"JetBrains Mono\", ui-monospace, SFMono-Regular, Menlo, monospace"
				}
			],
			"fontSizes": [
				{ "slug": "small", "name": "Small", "size": "0.875rem", "fluid": false },
				{ "slug": "medium", "name": "Medium", "size": "1rem", "fluid": false },
				{ "slug": "large", "name": "Large", "size": "1.25rem", "fluid": { "min": "1.125rem", "max": "1.25rem" } },
				{ "slug": "x-large", "name": "X-Large", "size": "1.75rem", "fluid": { "min": "1.5rem", "max": "1.75rem" } },
				{ "slug": "xx-large", "name": "2X-Large", "size": "2.5rem", "fluid": { "min": "2rem", "max": "2.5rem" } },
				{ "slug": "display", "name": "Display", "size": "3.75rem", "fluid": { "min": "2.5rem", "max": "3.75rem" } }
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"units": ["px", "em", "rem", "vh", "vw", "%"],
			"spacingSizes": [
				{ "slug": "20", "name": "1 / XS", "size": "0.5rem" },
				{ "slug": "30", "name": "2 / SM", "size": "0.75rem" },
				{ "slug": "40", "name": "3 / MD", "size": "1rem" },
				{ "slug": "50", "name": "4 / LG", "size": "1.5rem" },
				{ "slug": "60", "name": "5 / XL", "size": "2.5rem" },
				{ "slug": "70", "name": "6 / 2XL", "size": "4rem" },
				{ "slug": "80", "name": "7 / 3XL", "size": "6rem" }
			]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{ "slug": "sm", "name": "Small", "shadow": "0 1px 2px rgba(17, 17, 20, 0.06)" },
				{ "slug": "md", "name": "Medium", "shadow": "0 4px 16px rgba(17, 17, 20, 0.08)" },
				{ "slug": "lg", "name": "Large", "shadow": "0 12px 40px rgba(17, 17, 20, 0.12)" }
			]
		},
		"custom": {
			"radius": {
				"sm": "6px",
				"md": "12px",
				"lg": "20px",
				"pill": "999px"
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--sans)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.65"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--50)",
			"padding": {
				"top": "0",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--40)",
				"right": "var(--wp--preset--spacing--40)"
			}
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "600",
					"lineHeight": "1.15",
					"letterSpacing": "-0.02em"
				},
				"color": { "text": "var(--wp--preset--color--contrast)" }
			},
			"h1": { "typography": { "fontSize": "var(--wp--preset--font-size--display)" } },
			"h2": { "typography": { "fontSize": "var(--wp--preset--font-size--xx-large)" } },
			"h3": { "typography": { "fontSize": "var(--wp--preset--font-size--x-large)" } },
			"h4": { "typography": { "fontSize": "var(--wp--preset--font-size--large)" } },
			"link": {
				"color": { "text": "var(--wp--preset--color--primary)" },
				"typography": { "textDecoration": "none" },
				":hover": {
					"color": { "text": "var(--wp--preset--color--primary-hover)" },
					"typography": { "textDecoration": "underline" }
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--base)"
				},
				"border": { "radius": "var(--wp--custom--radius--pill)" },
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--30)",
						"bottom": "var(--wp--preset--spacing--30)",
						"left": "var(--wp--preset--spacing--50)",
						"right": "var(--wp--preset--spacing--50)"
					}
				},
				"typography": { "fontWeight": "600", "fontSize": "var(--wp--preset--font-size--medium)" },
				":hover": {
					"color": { "background": "var(--wp--preset--color--primary-hover)" }
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "700",
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"core/post-title": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--serif)" }
			},
			"core/pullquote": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--serif)" },
				"border": { "left": { "width": "3px", "color": "var(--wp--preset--color--primary)" } }
			},
			"core/quote": {
				"border": { "left": { "width": "3px", "color": "var(--wp--preset--color--primary)" } },
				"spacing": { "padding": { "left": "var(--wp--preset--spacing--50)" } }
			},
			"core/code": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--mono)", "fontSize": "var(--wp--preset--font-size--small)" },
				"color": { "background": "var(--wp--preset--color--surface)" },
				"border": { "radius": "var(--wp--custom--radius--md)" },
				"spacing": { "padding": { "top": "var(--wp--preset--spacing--40)", "bottom": "var(--wp--preset--spacing--40)", "left": "var(--wp--preset--spacing--40)", "right": "var(--wp--preset--spacing--40)" } }
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": [
		{ "name": "page-wide", "title": "Wide Page", "postTypes": ["page"] }
	]
}
