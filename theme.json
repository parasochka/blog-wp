{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "800px",
			"wideSize": "1280px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"customDuotone": false,
			"palette": [
				{ "slug": "base", "color": "#0f0f2d", "name": "Base / Background" },
				{ "slug": "base-deep", "color": "#080818", "name": "Base Deep" },
				{ "slug": "surface", "color": "#1e1e40", "name": "Surface" },
				{ "slug": "surface-elevated", "color": "#2e2e52", "name": "Surface Elevated" },
				{ "slug": "contrast", "color": "#ffffff", "name": "Contrast / Headings" },
				{ "slug": "text", "color": "#d0d0e0", "name": "Body Text" },
				{ "slug": "muted", "color": "#8080a8", "name": "Muted Text" },
				{ "slug": "border", "color": "#2b2b50", "name": "Border" },
				{ "slug": "primary", "color": "#5149e6", "name": "Primary / Brand" },
				{ "slug": "primary-hover", "color": "#3b34c0", "name": "Primary Hover" },
				{ "slug": "primary-light", "color": "#8a74ff", "name": "Primary Light" },
				{ "slug": "secondary", "color": "#6b55f5", "name": "Secondary" },
				{ "slug": "accent", "color": "#ffac34", "name": "Accent / Gaming" },
				{ "slug": "accent-strong", "color": "#f5900a", "name": "Accent Strong" },
				{ "slug": "success", "color": "#22c55e", "name": "Success" },
				{ "slug": "warning", "color": "#ffac34", "name": "Warning" },
				{ "slug": "error", "color": "#ef4444", "name": "Error" },
				{ "slug": "info", "color": "#3b82f6", "name": "Info" }
			],
			"gradients": [
				{ "slug": "brand", "gradient": "linear-gradient(135deg, #8a74ff 0%, #5149e6 100%)", "name": "Brand" },
				{ "slug": "deep-ocean", "gradient": "linear-gradient(135deg, #6b55f5 0%, #0f0f40 100%)", "name": "Deep Ocean" },
				{ "slug": "sunset", "gradient": "linear-gradient(135deg, #ffc05e 0%, #7060f0 100%)", "name": "Sunset" },
				{ "slug": "aurora", "gradient": "linear-gradient(135deg, #b09bff 0%, #ffac34 100%)", "name": "Aurora" },
				{ "slug": "purple-fade", "gradient": "linear-gradient(180deg, #ababff 0%, #0f0f40 100%)", "name": "Purple Fade" }
			]
		},
		"typography": {
			"fluid": true,
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"slug": "heading",
					"name": "Heading (Archivo Black)",
					"fontFamily": "\"Archivo Black\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif"
				},
				{
					"slug": "body",
					"name": "Body (42dot Sans)",
					"fontFamily": "\"42dot Sans\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif"
				},
				{
					"slug": "mono",
					"name": "Mono",
					"fontFamily": "\"JetBrains Mono\", ui-monospace, SFMono-Regular, Menlo, monospace"
				}
			],
			"fontSizes": [
				{ "slug": "small", "name": "Small (14)", "size": "0.875rem", "fluid": false },
				{ "slug": "medium", "name": "Body (16)", "size": "1rem", "fluid": false },
				{ "slug": "large", "name": "Body L (18)", "size": "1.125rem", "fluid": false },
				{ "slug": "x-large", "name": "H3 (28)", "size": "1.75rem", "fluid": { "min": "1.5rem", "max": "1.75rem" } },
				{ "slug": "xx-large", "name": "H2 (36)", "size": "2.25rem", "fluid": { "min": "1.875rem", "max": "2.25rem" } },
				{ "slug": "huge", "name": "H1 (48)", "size": "3rem", "fluid": { "min": "2.25rem", "max": "3rem" } },
				{ "slug": "display", "name": "Display (72)", "size": "4.5rem", "fluid": { "min": "2.75rem", "max": "4.5rem" } }
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"units": ["px", "em", "rem", "vh", "vw", "%"],
			"spacingSizes": [
				{ "slug": "10", "name": "1 (4)", "size": "0.25rem" },
				{ "slug": "20", "name": "2 (8)", "size": "0.5rem" },
				{ "slug": "30", "name": "3 (12)", "size": "0.75rem" },
				{ "slug": "40", "name": "4 (16)", "size": "1rem" },
				{ "slug": "50", "name": "5 (24)", "size": "1.5rem" },
				{ "slug": "60", "name": "6 (32)", "size": "2rem" },
				{ "slug": "70", "name": "7 (48)", "size": "3rem" },
				{ "slug": "80", "name": "8 (64)", "size": "4rem" },
				{ "slug": "90", "name": "9 (80)", "size": "5rem" },
				{ "slug": "100", "name": "10 (96)", "size": "6rem" },
				{ "slug": "110", "name": "11 (128)", "size": "8rem" }
			]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{ "slug": "card", "name": "Card (Level 1)", "shadow": "0 2px 8px rgba(0, 0, 0, 0.3)" },
				{ "slug": "glow", "name": "Brand Glow (Level 2)", "shadow": "0 8px 24px rgba(81, 73, 230, 0.2)" },
				{ "slug": "glow-strong", "name": "Strong Glow (Level 3)", "shadow": "0 16px 48px rgba(81, 73, 230, 0.4)" }
			]
		},
		"custom": {
			"radius": {
				"xs": "2px",
				"sm": "4px",
				"md": "8px",
				"lg": "12px",
				"xl": "16px",
				"2xl": "24px",
				"3xl": "32px",
				"pill": "9999px"
			},
			"color": {
				"primary": {
					"50": "#edeeff", "100": "#d4d5ff", "200": "#ababff", "300": "#8a74ff", "400": "#7060f0",
					"500": "#5149e6", "600": "#3b34c0", "700": "#2a2590", "800": "#1a1760", "900": "#0f0f40"
				},
				"neutral": {
					"0": "#ffffff", "50": "#f5f5fa", "100": "#eaeaf2", "200": "#d0d0e0", "300": "#ababc8",
					"400": "#8080a8", "500": "#5a5a80", "600": "#414168", "700": "#2e2e52", "800": "#1e1e40",
					"900": "#0f0f2d", "950": "#080818"
				},
				"accent": {
					"300": "#ffc05e", "400": "#ffac34", "500": "#f5900a", "600": "#d47004", "700": "#a55206"
				}
			},
			"ease": {
				"out": "cubic-bezier(0.23, 1, 0.32, 1)",
				"inOut": "cubic-bezier(0.77, 0, 0.175, 1)",
				"drawer": "cubic-bezier(0.32, 0.72, 0, 1)"
			},
			"duration": {
				"fast": "160ms",
				"base": "220ms",
				"slow": "320ms"
			},
			"z": {
				"sticky": "100",
				"overlay": "400",
				"modal": "500"
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--text)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.65"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--50)",
			"padding": {
				"top": "0",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--50)",
				"right": "var(--wp--preset--spacing--50)"
			}
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "400",
					"lineHeight": "1.12",
					"letterSpacing": "-0.01em"
				},
				"color": { "text": "var(--wp--preset--color--contrast)" }
			},
			"h1": { "typography": { "fontSize": "var(--wp--preset--font-size--huge)", "fontWeight": "400" } },
			"h2": { "typography": { "fontSize": "var(--wp--preset--font-size--xx-large)", "fontWeight": "400" } },
			"h3": { "typography": { "fontSize": "var(--wp--preset--font-size--x-large)" } },
			"h4": { "typography": { "fontSize": "var(--wp--preset--font-size--large)" } },
			"link": {
				"color": { "text": "var(--wp--preset--color--primary-light)" },
				"typography": { "textDecoration": "none" },
				":hover": {
					"color": { "text": "var(--wp--preset--color--secondary)" },
					"typography": { "textDecoration": "underline" }
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--contrast)"
				},
				"border": { "radius": "var(--wp--custom--radius--lg)" },
				"spacing": {
					"padding": {
						"top": "0.75rem",
						"bottom": "0.75rem",
						"left": "var(--wp--preset--spacing--50)",
						"right": "var(--wp--preset--spacing--50)"
					}
				},
				"typography": { "fontFamily": "var(--wp--preset--font-family--body)", "fontWeight": "600", "fontSize": "var(--wp--preset--font-size--medium)" },
				":hover": {
					"color": { "background": "var(--wp--preset--color--primary-hover)" }
				},
				":focus": {
					"color": { "background": "var(--wp--preset--color--primary-hover)" }
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "400",
					"fontSize": "var(--wp--preset--font-size--large)",
					"textTransform": "lowercase",
					"letterSpacing": "-0.02em"
				},
				"color": { "text": "var(--wp--preset--color--primary-light)" }
			},
			"core/post-title": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--heading)" }
			},
			"core/pullquote": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "400",
					"lineHeight": "1.2",
					"letterSpacing": "-0.01em"
				},
				"color": { "text": "var(--wp--preset--color--contrast)" },
				"border": {
					"top": { "width": "1px", "color": "var(--wp--preset--color--border)" },
					"bottom": { "width": "1px", "color": "var(--wp--preset--color--border)" }
				},
				"spacing": { "padding": { "top": "var(--wp--preset--spacing--60)", "bottom": "var(--wp--preset--spacing--60)" } }
			},
			"core/quote": {
				"color": { "text": "var(--wp--preset--color--text)", "background": "var(--wp--preset--color--surface)" },
				"border": { "radius": "var(--wp--custom--radius--xl)", "color": "var(--wp--preset--color--border)", "width": "1px", "style": "solid" },
				"spacing": { "padding": { "top": "var(--wp--preset--spacing--50)", "bottom": "var(--wp--preset--spacing--50)", "left": "var(--wp--preset--spacing--50)", "right": "var(--wp--preset--spacing--50)" } }
			},
			"core/code": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--mono)", "fontSize": "var(--wp--preset--font-size--small)" },
				"color": { "background": "var(--wp--preset--color--base-deep)", "text": "var(--wp--preset--color--text)" },
				"border": { "radius": "var(--wp--custom--radius--md)", "color": "var(--wp--preset--color--border)", "width": "1px", "style": "solid" },
				"spacing": { "padding": { "top": "var(--wp--preset--spacing--40)", "bottom": "var(--wp--preset--spacing--40)", "left": "var(--wp--preset--spacing--40)", "right": "var(--wp--preset--spacing--40)" } }
			},
			"core/separator": {
				"color": { "text": "var(--wp--preset--color--border)" }
			},
			"core/post-terms": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--heading)" }
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": [
		{ "name": "page-wide", "title": "Wide Page", "postTypes": ["page"] }
	]
}
